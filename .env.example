# ============================================
# Firebase Config (클라이언트용 - NEXT_PUBLIC_ 접두사)
# Firebase Console → 프로젝트 설정 → 일반 → SDK 설정
# ============================================
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ============================================
# Firebase Admin (서버용)
# Firebase Console → 프로젝트 설정 → 서비스 계정 → 새 비공개 키 생성
# ============================================
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# ============================================
# App Config
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ============================================
# OpenAI API
# https://platform.openai.com/api-keys
# ============================================
OPENAI_API_KEY=

# ============================================
# Cron Secret (Vercel Cron 인증용, 32자 이상 랜덤 문자열)
# ============================================
CRON_SECRET=

# ============================================
# Google OAuth (GA4 연동용)
# Google Cloud Console → APIs & Services → Credentials
# ============================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ============================================
# Instagram API (인스타그램 연동용)
# Meta Developer Console → App → Instagram Basic Display
# ============================================
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=

# ============================================
# Groq API (무료 - 리뷰 분석용 Llama 3.3 70B)
# https://console.groq.com/keys
# ============================================
GROQ_API_KEY=

# ============================================
# DeepSeek API (선택 - Groq 장애 시 폴백)
# https://platform.deepseek.com/api_keys
# ============================================
# DEEPSEEK_API_KEY=

# ============================================
# Inngest (무료 - 비동기 작업 파이프라인)
# https://app.inngest.com/
# ============================================
# INNGEST_EVENT_KEY=
# INNGEST_SIGNING_KEY=

# ============================================
# Email (선택 - Resend 또는 SendGrid 중 하나)
# ============================================
# RESEND_API_KEY=
# SENDGRID_API_KEY=
# EMAIL_FROM=noreply@staytrend.com
# ADMIN_EMAIL=admin@staytrend.com
